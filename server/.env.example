APP_PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Heroku AppLink — set automatically when the add-on is attached
# For local dev, provide manually
APP_LINK_CONNECTION_NAME=your_connection_name_here

# Agentforce
AGENTFORCE_AGENT_ID=your_agent_id_here

# Signature validation shared secret (must match VITE_API_SECRET in client)
API_SECRET=your_api_secret_here
